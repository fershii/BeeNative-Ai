{
  "name": "abejas-panama",
  "version": "1.0.0",
  "description": "Página web sobre abejas nativas de Panamá",
  "main": "server.js",
  "scripts": {
    "build-css": "tailwindcss -i ./src/styles.css -o ./public/styles.css",
    "watch-css": "tailwindcss -i ./src/styles.css -o ./public/styles.css --watch",
    "start": "node server.js",
    "dev": "npm run watch-css & node server.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "multer": "^2.2.0",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19"
  }
}
